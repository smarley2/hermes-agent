<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hermes.cloakbrowser</string>

  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/.local/bin/cloakserve-hermes</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/cloakbrowser.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/cloakbrowser.err.log</string>
</dict>
</plist>
